---
layout: null
---
[
  {% for post in site.posts %}
    {
      "title"    : {{ post.title | strip_html | escape | jsonify }},
      "url"      : {{ post.url | relative_url | jsonify }},
      "date"     : {{ post.date | date: "%Y-%m-%d" | jsonify }},
      "tags"     : {{ post.tags | join: " " | strip | jsonify }},
      "excerpt"  : {{ post.excerpt | strip_html | strip_newlines | truncate: 120 | jsonify }},
      "content"  : {{ post.content | strip_html | strip_newlines | truncate: 1000 | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
